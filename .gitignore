# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Node
node_modules/
npm-debug.log*

# Python
__pycache__/
*.pyc

# Generated test/run output from divi5-tools scripts
*-landing-page.json
*-seo-meta.json
*-schema.json
preview-*.html
generate-*.js

