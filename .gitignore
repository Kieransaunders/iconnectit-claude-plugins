# Local working notes (not committed)
*.notes.md

# Extractor output from style-variables/extract-from-export.js
*.tokens.js
*.variables.json
*.presets.json
# ...but keep bundled examples/fixtures
!plugins/divi5-tools/skills/**/examples/**
!plugins/divi5-tools/skills/**/__fixtures__/**
